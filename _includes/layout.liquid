<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title or "Attentix AI" }}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --dark: #0F0F0F;
            --darker: #050505;
            --surface: #1A1A1A;
            --electric: #00D9FF;
            --cyan: #00B4D8;
            --teal: #0099B6;
            --success: #10B981;
            --neutral-400: #9CA3AF;
            --neutral-500: #6B7280;
            --neutral-600: #4B5563;
            --neutral-700: #2D3748;
            --neutral-800: #1F2937;
        }

        body {
            font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background: var(--dark);
            color: #E5E7EB;
            line-height: 1.6;
        }

        /* Navigation */
        nav {
            background: var(--darker);
            backdrop-filter: blur(10px);
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--neutral-700);
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .logo {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--electric);
        }

        nav a {
            color: #A0AEC0;
            text-decoration: none;
            margin: 0 1.5rem;
            font-size: 0.9rem;
            transition: color 0.3s;
        }

        nav a:hover {
            color: var(--electric);
        }

        .nav-cta {
            background: var(--electric);
            color: var(--dark);
            padding: 0.5rem 1.25rem;
            border-radius: 0.375rem;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: background 0.3s;
        }

        .nav-cta:hover {
            background: var(--cyan);
        }

        /* Hero */
        .hero {
            padding: 6rem 2rem;
            text-align: center;
            background: linear-gradient(135deg, var(--darker) 0%, var(--surface) 100%);
            border-bottom: 1px solid var(--neutral-700);
        }

        .hero h1 {
            font-size: 3.5rem;
            font-weight: 700;
            line-height: 1.1;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #FFFFFF 0%, var(--electric) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .hero p {
            font-size: 1.25rem;
            color: var(--neutral-400);
            margin-bottom: 2rem;
            max-width: 700px;
            margin-left: auto;
            margin-right: auto;
        }

        .cta-buttons {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: var(--electric);
            color: var(--dark);
            padding: 1rem 2rem;
            border: none;
            border-radius: 0.5rem;
            font-weight: 600;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            background: var(--cyan);
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(0, 217, 255, 0.2);
        }

        .btn-secondary {
            background: transparent;
            color: var(--electric);
            padding: 1rem 2rem;
            border: 2px solid var(--electric);
            border-radius: 0.5rem;
            font-weight: 600;
            cursor: pointer;
            font-size: 1rem;
            transition: all 0.3s;
        }

        .btn-secondary:hover {
            background: rgba(0, 217, 255, 0.1);
            border-color: var(--cyan);
        }

        /* Section */
        section {
            padding: 4rem 2rem;
            border-bottom: 1px solid var(--neutral-700);
        }

        section h2 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 3rem;
            text-align: center;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
        }

        /* Footer */
        footer {
            background: var(--darker);
            border-top: 1px solid var(--neutral-700);
            padding: 3rem 2rem;
            text-align: center;
            color: var(--neutral-500);
            font-size: 0.9rem;
        }

        .footer-content {
            max-width: 1200px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 2rem;
            margin-bottom: 2rem;
            text-align: left;
        }

        .footer-section h4 {
            color: #E5E7EB;
            margin-bottom: 1rem;
            font-size: 0.95rem;
        }

        .footer-section a {
            color: var(--neutral-500);
            text-decoration: none;
            display: block;
            margin-bottom: 0.5rem;
            font-size: 0.85rem;
            transition: color 0.3s;
        }

        .footer-section a:hover {
            color: var(--electric);
        }

        @media (max-width: 768px) {
            .hero h1 {
                font-size: 2.5rem;
            }

            nav a {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav>
        <div class="logo">Attentix</div>
        <div>
            <a href="/">Home</a>
            <a href="/technology">Technology</a>
            <a href="/investors">For Investors</a>
            <a href="/about">About</a>
            <a href="/contact">Contact</a>
            <a href="#" class="nav-cta">Demo</a>
        </div>
    </nav>

    <!-- Content -->
    <main>
        {{ content }}
    </main>

    <!-- Footer -->
    <footer>
        <div class="footer-content">
            <div class="footer-section">
                <h4>Product</h4>
                <a href="/technology">Technology</a>
                <a href="/use-cases">Use Cases</a>
                <a href="/get-started">Get Started</a>
            </div>
            <div class="footer-section">
                <h4>Company</h4>
                <a href="/about">About</a>
                <a href="/careers">Careers</a>
                <a href="/blog">Blog</a>
            </div>
            <div class="footer-section">
                <h4>Legal</h4>
                <a href="/privacy">Privacy Policy</a>
                <a href="/terms">Terms</a>
                <a href="/security">Security</a>
            </div>
            <div class="footer-section">
                <h4>Connect</h4>
                <a href="#">LinkedIn</a>
                <a href="#">GitHub</a>
                <a href="#">Twitter</a>
            </div>
        </div>
        <div style="text-align: center; border-top: 1px solid #2D3748; padding-top: 2rem;">
            © 2026 Attentix AI. All rights reserved.
        </div>
    </footer>
</body>
</html>