{
  "project": {
    "name": "Attentix AI",
    "tagline": "Enterprise AI Infrastructure for Data-Driven Decision Making",
    "domain": "www.attentixai.com",
    "description": "A web-native pitch deck for venture capitalists and enterprise customers"
  },
  "designSystem": {
    "name": "Precision Noir",
    "philosophy": "Merging Umbrel's atmospheric premium feel with Linear's systematic engineering precision",
    "colorPalette": {
      "primary": {
        "dark": "#0F0F0F",
        "darker": "#050505",
        "surface": "#1A1A1A"
      },
      "accent": {
        "electric": "#00D9FF",
        "cyan": "#00B4D8",
        "teal": "#0099B6"
      },
      "semantic": {
        "success": "#10B981",
        "warning": "#F59E0B",
        "error": "#EF4444",
        "info": "#3B82F6"
      },
      "neutral": {
        "50": "#F9FAFB",
        "100": "#F3F4F6",
        "200": "#E5E7EB",
        "300": "#D1D5DB",
        "400": "#9CA3AF",
        "500": "#6B7280",
        "600": "#4B5563",
        "700": "#2D3748",
        "800": "#1F2937",
        "900": "#111827"
      }
    },
    "typography": {
      "fontFamily": {
        "sans": "\"Inter\", -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif",
        "mono": "\"JetBrains Mono\", \"Courier New\", monospace"
      },
      "scale": {
        "h1": { "size": "3.5rem", "weight": 700, "lineHeight": 1.1 },
        "h2": { "size": "2.5rem", "weight": 700, "lineHeight": 1.2 },
        "h3": { "size": "1.875rem", "weight": 600, "lineHeight": 1.3 },
        "body": { "size": "1rem", "weight": 400, "lineHeight": 1.6 },
        "bodySmall": { "size": "0.875rem", "weight": 400, "lineHeight": 1.5 },
        "label": { "size": "0.75rem", "weight": 600, "lineHeight": 1.4, "letterSpacing": "0.5px" }
      }
    },
    "spacing": {
      "xs": "0.25rem",
      "sm": "0.5rem",
      "md": "1rem",
      "lg": "1.5rem",
      "xl": "2rem",
      "2xl": "3rem",
      "3xl": "4rem",
      "4xl": "6rem"
    },
    "components": {
      "button": {
        "primary": {
          "bg": "#00D9FF",
          "text": "#0F0F0F",
          "hover": "#00B4D8"
        },
        "secondary": {
          "bg": "transparent",
          "text": "#00D9FF",
          "border": "#00D9FF",
          "hover": "#00B4D8"
        }
      },
      "card": {
        "bg": "#1A1A1A",
        "border": "#2D3748",
        "borderRadius": "0.5rem"
      }
    }
  },
