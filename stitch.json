  "flowArchitecture": {
    "description": "VC Funnel Architecture - Each page maps to specific investor questions",
    "funnelMap": {
      "awareness": ["1_homepage"],
      "interest": ["2_technology", "4_use_cases"],
      "evaluation": ["3_for_investors", "6_get_started"],
      "decision": ["7_contact"]
    },
    "numberedFlow": {
      "section": "How It Works",
      "steps": [
        { "number": "1.0", "label": "Ingest", "description": "Auto-connect to your data sources and extract patterns" },
        { "number": "2.0", "label": "Focus", "description": "Identify signal in noise with our proprietary AI framework" },
        { "number": "3.0", "label": "Predict", "description": "Generate actionable forecasts and recommendations" },
        { "number": "4.0", "label": "Act", "description": "Execute decisions with built-in workflow automation" }
      ]
    }
  },
  "trustSignals": {
    "approach": "industry-focused and factual capability statements",
    "signals": [
      {
        "type": "capability",
        "text": "Built for Fortune 500 data environments"
      },
      {
        "type": "compliance",
        "text": "Enterprise-grade security: SOC2 compliant architecture"
      },
      {
        "type": "scale",
        "text": "Processing 10B+ data points in testing"
      },
      {
        "type": "reliability",
        "text": "99.99% uptime SLA"
