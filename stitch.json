    "technologyPartners": [
      "Google Cloud Platform",
      "AWS",
      "Supabase",
      "PostgreSQL"
    ]
  },
  "buildConfig": {
    "framework": "Stitch",
    "contentApproach": "Markdown-first - each page has a .md content brief before generation",
    "buildLoop": "stitch-loop + design-md with baton files for systematic page-by-page generation",
    "outputFormat": "Static HTML/CSS with component reusability",
    "deploymentTarget": "Vercel / Netlify",
    "seo": {
      "lang": "en",
      "charset": "utf-8",
      "ogImage": "/og-default.png",
      "appleTouchIcon": "/apple-touch-icon.png"
    },
    "analytics": {
      "gtag": "G-XXXXXXXXXX",
      "hotjar": "3700000"
    }
  },
